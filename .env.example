# ── WiseTech Image MCP Server — environment config template ──────────────
# Copy this file to ".env" and fill in your values.
# The real .env is gitignored and never committed.

# YOUR key that protects this MCP server. Clients must send:
#   Authorization: Bearer <this value>
# Generate with: openssl rand -hex 32
MCP_AUTH_KEY=

# ── WiseTech API base URLs ──────────────────────────────────────────────
# Auto-resolved from DNS on startup, refreshed every 6 hours:
WISETECH_MAIN_DNS=https://sd.rad-wi.com
WISETECH_BG_DNS=https://ibgc.rad-wi.com/

# Fallback IPs used only if DNS resolution fails:
WISETECH_MAIN_FALLBACK=http://34.232.100.156:5454
WISETECH_BG_FALLBACK=http://35.190.164.209:5454

# Pin specific hosts ONLY if you want to skip DNS (IPs rotate daily!):
# WISETECH_MAIN_API_URL=http://34.232.100.156:5454
# WISETECH_BG_API_URL=http://35.190.164.209:5454

# ── WiseTech API auth (not needed — IP-whitelisted) ──────────────────────
WISETECH_API_KEY=
WISETECH_AUTH_HEADER=

# ── Server ──────────────────────────────────────────────────────────────
PORT=3000

# HTTPS: path to Let's Encrypt cert directory (leave empty for HTTP/local)
# When set, the server uses HTTPS directly (no nginx needed)
# Example: HTTPS_CERT_DIR=/etc/letsencrypt/live/mcp.yourdomain.com
HTTPS_CERT_DIR=